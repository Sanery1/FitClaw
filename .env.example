# ============================================================================
# FitClaw Bot 配置文件
# 复制为 .env 并填入真实值: cp .env.example .env
# 改这里一处，Docker / PM2 / 手动启动全部生效
# ============================================================================

# --- Bot 平台 (选一个) ---
# 飞书:
MOM_FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
MOM_FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOM_FEISHU_BOT_NAME=FitCoach

# Slack (如果用 Slack):
# MOM_SLACK_APP_TOKEN=xapp-xxxxxxxx
# MOM_SLACK_BOT_TOKEN=xoxb-xxxxxxxx

# --- LLM 配置 ---
MOM_LLM_PROVIDER=deepseek
MOM_LLM_MODEL=deepseek-v3

# --- LLM API Key ---
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 如果用其他 Provider，改上面的 MOM_LLM_PROVIDER 并填对应的 API Key:
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# OPENAI_API_KEY=sk-proj-xxxxxxxx
# MINIMAX_API_KEY=xxxxxxxx
# GEMINI_API_KEY=xxxxxxxx
# GROQ_API_KEY=xxxxxxxx
# XAI_API_KEY=xxxxxxxx
# FIREWORKS_API_KEY=xxxxxxxx
# OPENROUTER_API_KEY=xxxxxxxx
# MISTRAL_API_KEY=xxxxxxxx
# KIMI_API_KEY=xxxxxxxx
