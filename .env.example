# ============================================================================
# FitClaw Bot 配置文件 — 唯一真相源
# 复制为 .env 并填入真实值: cp .env.example .env
# 改这里一处，Docker / PM2 / 手动启动全部生效
#
# 重要：改配置后必须重建容器才能生效：
#   docker compose down && docker compose up -d
# ============================================================================

# --- Bot 平台 ---
# 飞书:
MOM_FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
MOM_FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOM_FEISHU_BOT_NAME=FitCoach

# --- LLM 配置 ---
# Provider、模型、代理地址。entrypoint.sh 启动时自动生成 auth.json + models.json
MOM_LLM_PROVIDER=deepseek
MOM_LLM_MODEL=deepseek-v4-flash
MOM_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOM_LLM_BASE_URL=https://api.deepseek.com
MOM_LLM_API_TYPE=openai-completions
