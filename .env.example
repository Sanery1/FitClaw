# --- Bot 平台 (选一个) ---
# 飞书:
MOM_FEISHU_APP_ID=cli_a927dfbe2e781bb6
MOM_FEISHU_APP_SECRET=hgqkrz8ThD7j7uMA2JzEwbPR8JTP05Lz
MOM_FEISHU_BOT_NAME=FitCoach

# Slack (如果用 Slack):
# MOM_SLACK_APP_TOKEN=xapp-xxxxxxxx
# MOM_SLACK_BOT_TOKEN=xoxb-xxxxxxxx

# --- LLM 配置（与 CLI 共用 ~/.fitclaw/agent/ 的配置） ---
MOM_LLM_PROVIDER=MiniMax
MOM_LLM_MODEL=MiniMax-M2.7-highspeed

# --- LLM API Key ---
MINIMAX_API_KEY=sk-c7d23878281e9f93dd2f5585094aa384

# 如果用其他 Provider，改上面的 MOM_LLM_PROVIDER 并填对应的 API Key:
