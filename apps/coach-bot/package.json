{
	"name": "@fitclaw/coach-bot",
	"version": "0.70.5",
	"description": "FitClaw's Feishu-first AI fitness coach application",
	"private": true,
	"type": "module",
	"bin": {
		"fitclaw-coach": "dist/main.js"
	},
	"files": [
		"dist",
		"CHANGELOG.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && shx chmod +x dist/main.js && shx mkdir -p dist/evals && shx cp evals/*.yaml dist/evals/",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"test": "vitest --run",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@fitclaw/agent-core": "^0.70.5",
		"@fitclaw/ai": "^0.70.5",
		"@fitclaw/coach-core": "^0.70.5",
		"@fitclaw/runtime": "^0.70.5",
		"@larksuiteoapi/node-sdk": "^1.6.0",
		"chalk": "^5.6.2",
		"croner": "^9.1.0",
		"diff": "^8.0.2",
		"pdfjs-dist": "5.4.394",
		"typebox": "^1.1.24",
		"yaml": "^2.8.2"
	},
	"devDependencies": {
		"@types/diff": "^7.0.2",
		"@types/node": "^24.3.0",
		"typescript": "^5.7.3",
		"vitest": "^3.2.4"
	},
	"keywords": [
		"feishu",
		"bot",
		"ai",
		"agent"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Sanery1/FitClaw.git",
		"directory": "apps/coach-bot"
	},
	"engines": {
		"node": ">=22.5.0"
	}
}
