{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@fitclaw/ai": ["./packages/ai/src/index.ts"],
			"@fitclaw/ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@fitclaw/ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@fitclaw/ai/dist/*": ["./packages/ai/src/*"],
			"@fitclaw/agent-core": ["./packages/agent/src/index.ts"],
			"@fitclaw/agent-core/*": ["./packages/agent/src/*"],
			"@fitclaw/claw": ["./packages/coding-agent/src/index.ts"],
			"@fitclaw/claw/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@fitclaw/claw/*": ["./packages/coding-agent/src/*"],
			"@fitclaw/coach-core": ["./packages/coach-core/src/index.ts"],
			"@fitclaw/coach-core/*": ["./packages/coach-core/src/*"],
			"@fitclaw/runtime": ["./packages/runtime/src/index.ts"],
			"@fitclaw/runtime/*": ["./packages/runtime/src/*"],
			"typebox": ["./node_modules/typebox"],
			"@fitclaw/coach-bot": ["./apps/coach-bot/src/main.ts"],
			"@fitclaw/coach-bot/*": ["./apps/coach-bot/src/*"],
			"@fitclaw/tui": ["./packages/tui/src/index.ts"],
			"@fitclaw/tui/*": ["./packages/tui/src/*"],
			"@fitclaw/web-ui": ["./packages/web-ui/src/index.ts"],
			"@fitclaw/web-ui/*": ["./packages/web-ui/src/*"]
		}
	},
	"include": ["apps/*/src/**/*", "apps/*/test/**/*", "packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": ["packages/web-ui/**/*", "**/dist/**"]
}
